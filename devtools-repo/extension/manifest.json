{
  "manifest_version": 3,
  "name": "DevTools — Boîte à outils",
  "version": "1.2.0",
  "description": "JSON/XML/SQL formatter, JWT decoder, Base64, Timestamp, Diff, UUID, Form Tools — tout en un.",

  "update_url": "https://quenaultthomas.github.io/devtools-extension/updates.xml",

  "action": {
    "default_popup": "devtools.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "DevTools"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "clipboardRead",
    "clipboardWrite"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
